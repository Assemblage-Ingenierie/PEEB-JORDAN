# ── Supabase ───────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your project values.
# Find these in: Supabase Dashboard → Project Settings → API

# Project URL (e.g. https://xxxxxxxxxxxx.supabase.co)
VITE_SUPABASE_URL=

# Anon / publishable key — safe to expose in the browser
# New format: sb_publishable_xxx  |  Legacy format: eyJ...
VITE_SUPABASE_ANON_KEY=

# ── Google sign-in (Identity Services) ──────────────────────────────────────────
# The *Web* OAuth 2.0 client ID from Google Cloud Console → Credentials.
# Used by the in-app "Sign in with Google" button (signInWithIdToken), so Google's
# consent screen shows OUR domain instead of the Supabase project URL.
# Add every origin that serves the app (prod, previews, localhost) to that client's
# "Authorized JavaScript origins". Ends with .apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=
